# Configuração do banco de dados SQLite (100% gratuito)
DATABASE_PATH=data/app.db

# Configuração da API (opcional - se não configurado, usa regras predefinidas)
# OPENAI_API_KEY=sk-sua-chave-aqui

# Configuração do servidor
HOST=0.0.0.0
PORT=8000

# Logging
LOG_LEVEL=INFO

# Cache (em memória - não requer configuração)
# O cache é gerenciado automaticamente pelo SQLite
